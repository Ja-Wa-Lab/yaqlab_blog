{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PostFrontmatter",
  "type": "object",
  "required": ["title","slug","date","status","lang","tags","excerpt","hero_image","hero_alt","hero_h1","seo_title","seo_description","source_type","source_ref"],
  "properties": {
    "title": {"type":"string","minLength":8},
    "slug": {"type":"string","minLength":3},
    "date": {"type":"string","format":"date"},
    "status": {"type":"string","enum":["draft","ready"]},
    "lang": {"type":"string","enum":["pl","en"]},
    "tags": {"type":"array","minItems":1,"items":{"type":"string"}},
    "excerpt": {"type":"string","minLength":40},
    "hero_image": {"type":"string"},
    "hero_alt": {"type":"string","minLength":10},
    "hero_h1": {"type":"string","minLength":3},
    "seo_title": {"type":"string","minLength":10},
    "seo_description": {"type":"string","minLength":50},
    "source_type": {"type":"string","const":"voice_chat"},
    "source_ref": {"type":"string","minLength":3}
  }
}
