---
const { title = 'yaqlab blog', description = 'AI, infra, procesy' } = Astro.props;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #ffffff;
        --surface: #ffffff;
        --surface-soft: #f7f7f8;
        --text: #1a1a1a;
        --muted: #6b7280;
        --border: #e8e8eb;
        --link: #1f5eff;
      }

      * { box-sizing: border-box; }

      body {
        font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
        margin: 0;
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
      }

      .wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: clamp(1rem, 3vw, 2rem) 1rem 4rem;
      }

      h1, h2, h3 {
        line-height: 1.25;
        letter-spacing: -0.01em;
        margin-top: 0;
      }

      p { margin: 0.6rem 0 1rem; }

      a {
        color: var(--link);
        text-decoration: none;
      }

      a:hover { text-decoration: underline; }

      .card {
        border: 1px solid var(--border);
        background: var(--surface);
        border-radius: 16px;
        padding: 1rem;
      }

      .hero {
        position: relative;
        margin: 1.2rem 0 2rem;
        border-radius: 20px;
        overflow: hidden;
        max-height: min(78vh, 860px);
        background: var(--surface-soft);
      }

      .hero img {
        width: 100%;
        height: auto;
        max-height: min(78vh, 860px);
        object-fit: cover;
        display: block;
      }

      .hero h1 {
        position: absolute;
        left: clamp(0.8rem, 2vw, 1.2rem);
        bottom: clamp(0.8rem, 2vw, 1.2rem);
        margin: 0;
        padding: 0.45rem 0.85rem;
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.66);
        color: #fff;
        font-size: clamp(1.15rem, 2.4vw, 1.8rem);
        max-width: min(90%, 700px);
      }

      .meta {
        color: var(--muted);
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <main class="wrap"><slot /></main>
  </body>
</html>
