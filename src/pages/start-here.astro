---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const readyPosts = (await getCollection('posts'))
  .filter((post) => post.data.status === 'ready')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const topPosts = readyPosts.slice(0, 5);
---
<BaseLayout
  title="Start here | YAQ Lab Notes"
  description="Najlepszy punkt startowy: najważniejsze wpisy o AI, infrastrukturze i bezpieczeństwie."
  canonical="/start-here/"
>
  <p style="margin:0 0 1rem;"><a href="./">← Wróć do landingu</a></p>
  <h1>Start here</h1>
  <p>
    Jeśli jesteś tu pierwszy raz, zacznij od tych wpisów. To przekrojowy zestaw tematów: AI, procesy,
    infrastruktura i bezpieczeństwo — bez korpomowy, konkretnie i wdrożeniowo.
  </p>

  <section class="card" style="margin:1rem 0 1.2rem;">
    <h2 style="margin-bottom:.5rem;">Jak czytać ten blog</h2>
    <ul>
      <li><strong>AI / Ops</strong> — jak zamieniać rozmowy i pomysły w działający proces.</li>
      <li><strong>Infra / DevOps</strong> — Docker, VPS, praktyka wdrożeń.</li>
      <li><strong>Security</strong> — Zero Trust, VPN i decyzje architektoniczne.</li>
      <li><strong>Product / Process</strong> — wymagania, user stories, empatia i delivery.</li>
    </ul>
  </section>

  <h2>5 wpisów na start</h2>
  <ul style="list-style:none;padding:0;display:grid;gap:.8rem;">
    {topPosts.map((post) => (
      <li class="card">
        <a href={`posts/${post.slug}/`}><strong>{post.data.title}</strong></a>
        <div class="meta">{post.data.date.toISOString().slice(0,10)} · {post.data.lang.toUpperCase()}</div>
        <p style="margin:.35rem 0 0;">{post.data.excerpt}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
