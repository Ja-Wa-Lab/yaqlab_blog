---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.status === 'ready')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<BaseLayout title="yaqlab.com" description="Blog o AI, infrastrukturze i procesach">
  <h1>yaqlab.com</h1>
  <p>Wpisy tworzone z rozmów i publikowane workflowem GitHub PR.</p>
  <ul>
    {posts.map((post) => (
      <li><a href={`/posts/${post.data.slug}/`}>{post.data.title}</a> — {post.data.date.toISOString().slice(0,10)}</li>
    ))}
  </ul>
</BaseLayout>
